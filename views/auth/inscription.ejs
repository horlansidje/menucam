<%- include('../partials/head',{title:'Inscription'}) %>
<link rel="stylesheet" href="/css/auth.css"/>
<div class="auth-page">
  <div class="auth-left">
    <a href="/" class="back-link">← Retour</a>
    <div class="auth-wax"></div>
    <div class="auth-brand"><span class="brand-icon">🍽️</span><span class="brand-name">MenuCam</span></div>
    <h1>Créez votre compte</h1>
    <p>Votre menu digital prêt en 5 minutes.</p>
    <% if(error&&error.length>0){%><div class="alert alert-error"><%=error%></div><%}%>
    <form method="POST" action="/auth/inscription" class="auth-form">
      <div class="form-group"><label>Nom du restaurant *</label><input type="text" name="nom" placeholder="Ex: Chez Maman Biya" required/></div>
      <div class="form-row">
        <div class="form-group"><label>Email *</label><input type="email" name="email" placeholder="contact@monresto.cm" required/></div>
        <div class="form-group"><label>Téléphone *</label><input type="tel" name="telephone" placeholder="6XX XXX XXX" required/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Adresse</label><input type="text" name="adresse" placeholder="Quartier, Rue..."/></div>
        <div class="form-group"><label>Ville</label><select name="ville"><option>Douala</option><option>Yaoundé</option><option>Bafoussam</option><option>Bamenda</option><option>Garoua</option><option>Autre</option></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Mot de passe *</label><input type="password" name="password" placeholder="Min. 6 caractères" required minlength="6"/></div>
        <div class="form-group"><label>Confirmer *</label><input type="password" name="password2" placeholder="Répétez" required/></div>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;margin-top:0.5rem">Créer mon compte →</button>
    </form>
    <p class="auth-switch">Déjà un compte ? <a href="/auth/connexion">Se connecter</a></p>
  </div>
  <div class="auth-right">
    <div class="auth-illustration">
      <div class="illus-phone"><div class="illus-qr-box"><div class="qr-c tl"></div><div class="qr-c tr"></div><div class="qr-c bl"></div><div style="background:rgba(255,255,255,0.05);border-radius:6px"></div></div><p style="color:rgba(255,255,255,0.5);font-size:14px;margin-top:1rem">Votre QR code unique</p></div>
    </div>
  </div>
</div>
</body></html>
