<%- include('../partials/head',{title:'Mon profil'}) %>
<link rel="stylesheet" href="/css/dashboard.css"/>
<%- include('../partials/navbar',{activePage:'profil'}) %>
<div class="page-wrapper">
  <div class="page-header"><div><h1 class="page-title">⚙️ Mon profil</h1><p class="page-sub">Informations de votre restaurant</p></div></div>
  <% if(error&&error.length>0){%><div class="alert alert-error"><%=error%></div><%}%>
  <% if(success&&success.length>0){%><div class="alert alert-success"><%=success%></div><%}%>
  <div class="form-card">
    <form method="POST" action="/dashboard/profil" enctype="multipart/form-data">
      <div class="form-grid">
        <div>
          <div class="form-group"><label>Logo du restaurant</label>
            <div class="photo-upload" id="photoUpload">
              <%if(restaurant.logo){%><img src="<%=restaurant.logo%>" id="photoPreview" class="photo-preview"/><%}else{%>
              <div class="photo-placeholder" id="photoPlaceholder"><span class="upload-icon">🍽️</span><span>Ajouter votre logo</span><span class="upload-sub">JPG, PNG · Max 3 Mo</span></div>
              <img id="photoPreview" class="photo-preview" style="display:none"/><%}%>
              <input type="file" name="logo" id="photoInput" accept="image/*" style="display:none"/>
            </div>
          </div>
        </div>
        <div>
          <div class="form-group"><label>Nom *</label><input type="text" name="nom" value="<%=restaurant.nom%>" required/></div>
          <div class="form-group"><label>Téléphone *</label><input type="tel" name="telephone" value="<%=restaurant.telephone%>" required/></div>
          <div class="form-row">
            <div class="form-group"><label>Adresse</label><input type="text" name="adresse" value="<%=restaurant.adresse||''%>"/></div>
            <div class="form-group"><label>Ville</label><select name="ville"><%['Douala','Yaoundé','Bafoussam','Bamenda','Garoua','Autre'].forEach(v=>{%><option value="<%=v%>" <%=restaurant.ville===v?'selected':''%>><%=v%></option><%});%></select></div>
          </div>
          <div class="form-group"><label>Description</label><textarea name="description" rows="3"><%=restaurant.description||''%></textarea></div>
        </div>
      </div>
      <div class="form-actions"><a href="/dashboard" class="btn btn-outline">Annuler</a><button type="submit" class="btn btn-primary">💾 Enregistrer</button></div>
    </form>
  </div>
</div>
<script>
const pu=document.getElementById('photoUpload'),pi=document.getElementById('photoInput'),pp=document.getElementById('photoPreview'),ph=document.getElementById('photoPlaceholder');
pu.addEventListener('click',()=>pi.click());
pi.addEventListener('change',e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{pp.src=ev.target.result;pp.style.display='block';if(ph)ph.style.display='none';};r.readAsDataURL(f);});
</script>
<script src="/js/navbar.js"></script>
</body></html>
