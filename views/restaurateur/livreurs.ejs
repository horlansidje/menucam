<%- include('../partials/head', {title:'Livreurs'}) %>
<%- include('../partials/sidebar', {activePage:'livreurs'}) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="/css/leaflet-custom.css"/>
<div class="main-content">
  <div class="topbar">
    <div class="topbar-left">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button>
      <div class="topbar-title">Gestion des livreurs</div>
    </div>
    <div class="topbar-right">
      <div class="live-chip"><span class="status-dot"></span> Temps réel</div>
    </div>
  </div>
  <div class="page-body">
    <% if(error&&error.length>0){%><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i><%=error%></div><%}%>
    <% if(success&&success.length>0){%><div class="alert alert-success"><i class="bi bi-check-circle"></i><%=success%></div><%}%>

    <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start;margin-bottom:1.5rem">
      <!-- Liste livreurs -->
      <div>
        <% if(livreurs.length===0){ %>
          <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-scooter"></i></div>
            <h3>Aucun livreur enregistré</h3>
            <p>Ajoutez vos livreurs pour gérer et suivre les livraisons sur la carte.</p>
          </div>
        <% } else { %>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
            <%livreurs.forEach((l,li)=>{
              const colors=['#F59E0B','#3B82F6','#10B981','#EF4444','#8B5CF6','#F97316','#14B8A6'];
              const color=colors[li%colors.length];
            %>
              <div class="card">
                <div class="card-body" style="display:flex;align-items:center;gap:1rem">
                  <div style="width:52px;height:52px;border-radius:50%;background:<%=color%>22;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;border:3px solid <%=color%>">🛵</div>
                  <div style="flex:1;min-width:0">
                    <div style="font-weight:800;font-size:15px;color:var(--text-primary)"><%=l.nom%></div>
                    <div style="font-size:13px;color:var(--text-secondary)"><i class="bi bi-telephone"></i> <%=l.telephone%></div>
                    <%if(l.moto){%><div style="font-size:12px;color:var(--text-tertiary)">🏍️ <%=l.moto%></div><%}%>
                    <%if(l.zone){%><div style="font-size:12px;color:var(--text-tertiary)"><i class="bi bi-geo-alt"></i> <%=l.zone%></div><%}%>
                    <div style="font-size:11px;color:var(--accent-dark);margin-top:3px"><i class="bi bi-check2-circle"></i> <%=l.commandes_livrees||0%> livraison(s)</div>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;flex-shrink:0">
                    <select onchange="updateStatut('<%=l._id%>',this.value)" class="form-control form-select" style="font-size:12px;padding:4px 8px;height:32px;width:130px;border-color:<%=color%>">
                      <option value="disponible" <%= l.statut==='disponible' ? 'selected' : '' %>>✅ Disponible</option>
                      <option value="occupé"     <%= l.statut==='occupé'     ? 'selected' : '' %>>🟡 Occupé</option>
                      <option value="inactif"    <%= l.statut==='inactif'    ? 'selected' : '' %>>⚫ Inactif</option>
                    </select>
                    <div style="display:flex;gap:4px">
                      <button onclick="centrerLivreur('<%=l._id%>')" class="btn btn-ghost btn-sm btn-icon" title="Voir sur carte"><i class="bi bi-map"></i></button>
                      <form method="POST" action="/livreurs/<%=l._id%>/supprimer" onsubmit="return confirm('Supprimer ce livreur ?')"><button type="submit" class="btn btn-secondary btn-sm btn-icon"><i class="bi bi-trash3"></i></button></form>
                    </div>
                  </div>
                </div>
              </div>
            <%});%>
          </div>
        <%}%>
      </div>

      <!-- Formulaire ajout livreur -->
      <div class="card">
        <div class="card-header-bar"><div class="card-title">➕ Nouveau livreur</div></div>
        <div class="card-body">
          <form method="POST" action="/livreurs/nouveau">
            <div style="margin-bottom:.9rem">
              <label class="form-label">Nom complet *</label>
              <div class="input-group"><i class="bi bi-person"></i><input type="text" name="nom" class="form-control" placeholder="Ex: Jean-Paul Mbarga" required/></div>
            </div>
            <div style="margin-bottom:.9rem">
              <label class="form-label">Téléphone *</label>
              <div class="input-group"><i class="bi bi-telephone"></i><input type="tel" name="telephone" class="form-control" placeholder="6XX XXX XXX" required/></div>
            </div>
            <div style="margin-bottom:.9rem">
              <label class="form-label">Type de moto</label>
              <input type="text" name="moto" class="form-control" placeholder="Ex: TVS King, Benelli, DF200"/>
            </div>
            <div style="margin-bottom:1.25rem">
              <label class="form-label">Zone de couverture</label>
              <input type="text" name="zone" class="form-control" placeholder="Ex: Akwa, Bonamoussadi, Kotto..."/>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%"><i class="bi bi-person-plus"></i> Ajouter le livreur</button>
          </form>
        </div>
      </div>
    </div>

    <!-- ══ CARTE DES LIVRAISONS ══ -->
    <div class="card">
      <div class="card-header-bar">
        <div>
          <div class="card-title"><i class="bi bi-map"></i> Carte des livraisons en cours</div>
          <div class="card-subtitle">Positions des commandes assignées à vos livreurs</div>
        </div>
        <div style="display:flex;gap:8px">
          <button onclick="refreshLivreursMap()" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-clockwise"></i> Actualiser</button>
          <span id="mapStatusBadge" class="badge badge-gray">Chargement...</span>
        </div>
      </div>
      <div id="livreursMap" class="leaflet-map-wrap" style="height:480px;border-radius:0 0 16px 16px"></div>
      <div class="card-body" style="padding:.75rem 1.25rem">
        <div class="map-legend" id="livreursLegend">
          <div class="legend-item"><div class="legend-dot" style="background:#1B4332"></div> Votre restaurant</div>
          <div class="legend-item"><div class="legend-dot" style="background:#F59E0B"></div> En attente (sans livreur)</div>
          <% livreurs.forEach((l,li)=>{
            const colors=['#F59E0B','#3B82F6','#10B981','#EF4444','#8B5CF6','#F97316','#14B8A6'];
            const color=colors[li%colors.length];
          %>
            <div class="legend-item"><div class="legend-dot" style="background:<%=color%>"></div> <%=l.nom%></div>
          <%});%>
        </div>
        <!-- Stats rapides -->
        <div id="mapStats" style="display:flex;flex-wrap:wrap;gap:10px;margin-top:10px"></div>
      </div>
    </div>

  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/map-dashboard.js"></script>
<script src="/js/app.js"></script>
<script>
let livreursMapInstance = null;
const livreursList = <%- JSON.stringify(livreurs) %>;

async function loadLivreursMap() {
  try {
    const [commandes, restaurant] = await Promise.all([
      fetch('/maps/commandes').then(r => r.json()),
      fetch('/maps/restaurant').then(r => r.json()),
    ]);

    // Nettoyer ancienne carte
    if (livreursMapInstance) {
      livreursMapInstance.remove();
      livreursMapInstance = null;
      const el = document.getElementById('livreursMap');
      el.innerHTML = '';
    }

    // Stats
    const enCours   = commandes.filter(c => c.statut === 'en_livraison').length;
    const enAttente = commandes.filter(c => c.statut === 'en_attente').length;
    const statsEl = document.getElementById('mapStats');
    if (statsEl) {
      statsEl.innerHTML = `
        <span class="badge badge-purple" style="font-size:12px">🛵 ${enCours} en livraison</span>
        <span class="badge badge-warning" style="font-size:12px">⏳ ${enAttente} en attente</span>
        <span class="badge badge-gray" style="font-size:12px">📦 ${commandes.length} total</span>
      `;
    }

    livreursMapInstance = initLivreursMap(commandes, livreursList, restaurant);

    const badge = document.getElementById('mapStatusBadge');
    if (badge) {
      badge.className = 'badge badge-success';
      badge.innerHTML = `✅ ${commandes.length} livraison(s)`;
    }
  } catch(e) {
    console.error('Erreur chargement carte livreurs:', e);
    const badge = document.getElementById('mapStatusBadge');
    if (badge) { badge.className = 'badge badge-danger'; badge.textContent = '❌ Erreur'; }
  }
}

function refreshLivreursMap() {
  const badge = document.getElementById('mapStatusBadge');
  if (badge) { badge.className = 'badge badge-gray'; badge.textContent = 'Chargement...'; }
  loadLivreursMap();
}

function centrerLivreur(livreurId) {
  // Scroll vers la carte
  document.getElementById('livreursMap').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

async function updateStatut(id, statut) {
  await fetch(`/livreurs/${id}/statut`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ statut })
  });
  showToast(`Statut mis à jour : ${statut}`, 'success');
}

// Charger la carte au démarrage
loadLivreursMap();

// Auto-refresh toutes les 30 secondes
setInterval(refreshLivreursMap, 30000);
</script>
</body></html>
