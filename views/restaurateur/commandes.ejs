<%- include('../partials/head', {title:'Commandes'}) %>
<%- include('../partials/sidebar', {activePage:'commandes', enAttenteCount: stats.enAttente}) %>

<div class="main-content">

  <!-- TOPBAR -->
  <div class="topbar">

    <div class="topbar-left">

      <button class="sidebar-toggle" id="sidebarToggle">
        <i class="bi bi-list"></i>
      </button>

      <div class="topbar-title">
        Commandes
      </div>

    </div>

    <div class="topbar-right">

      <div class="live-chip">
        <span class="status-dot"></span>
        Temps réel
      </div>

    </div>

  </div>

  <!-- PAGE -->
  <div class="page-body">

    <% if(success && success.length > 0){ %>

      <div class="alert alert-success">

        <i class="bi bi-check-circle"></i>

        <%= success %>

      </div>

    <% } %>

    <!-- STATS -->
    <div class="stats-row">

      <div class="stat-card stat-brand">
        <div class="stat-card-icon" style="background:#FEF3C7;color:#D97706">
          <i class="bi bi-clock" style="font-size:1.3rem"></i>
        </div>
        <div class="stat-card-value"><%= stats.enAttente %></div>
        <div class="stat-card-label">En attente</div>
      </div>

      <div class="stat-card stat-blue">
        <div class="stat-card-icon" style="background:#DBEAFE;color:#2563EB">
          <i class="bi bi-fire" style="font-size:1.3rem"></i>
        </div>
        <div class="stat-card-value"><%= stats.enPreparation %></div>
        <div class="stat-card-label">En préparation</div>
      </div>

      <div class="stat-card stat-purple">
        <div class="stat-card-icon" style="background:#EDE9FE;color:#7C3AED">
          <i class="bi bi-scooter" style="font-size:1.3rem"></i>
        </div>
        <div class="stat-card-value"><%= stats.enLivraison %></div>
        <div class="stat-card-label">En livraison</div>
      </div>

      <div class="stat-card stat-green">
        <div class="stat-card-icon" style="background:#D1FAE5;color:#059669">
          <i class="bi bi-check-circle" style="font-size:1.3rem"></i>
        </div>
        <div class="stat-card-value"><%= stats.servies %></div>
        <div class="stat-card-label">Servies/Livrées</div>
      </div>

      <div class="stat-card stat-brand">
        <div class="stat-card-icon" style="background:#FEF3C7;color:#D97706">
          <i class="bi bi-wallet2" style="font-size:1.3rem"></i>
        </div>
        <div class="stat-card-value">
          <%= stats.caToday.toLocaleString('fr-FR') %>
        </div>
        <div class="stat-card-label">
          FCFA aujourd'hui
        </div>
      </div>

    </div>

    <!-- FILTRES -->
    <div class="card" style="margin-bottom:1.5rem">

      <div class="card-body" style="padding:.75rem 1.25rem">

        <form method="GET" action="/commandes"
              style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">

          <select name="statut"
                  class="form-control form-select"
                  style="width:180px"
                  onchange="this.form.submit()">

            <option value="toutes"
              <%= filtreStatut==='toutes' ? 'selected' : '' %>>
              Toutes les commandes
            </option>

            <option value="en_attente"
              <%= filtreStatut==='en_attente' ? 'selected' : '' %>>
              ⏳ En attente
            </option>

            <option value="en_preparation"
              <%= filtreStatut==='en_preparation' ? 'selected' : '' %>>
              👨‍🍳 En préparation
            </option>

            <option value="en_livraison"
              <%= filtreStatut==='en_livraison' ? 'selected' : '' %>>
              🛵 En livraison
            </option>

            <option value="servie"
              <%= filtreStatut==='servie' ? 'selected' : '' %>>
              ✅ Servies
            </option>

            <option value="annulee"
              <%= filtreStatut==='annulee' ? 'selected' : '' %>>
              ❌ Annulées
            </option>

          </select>

          <select name="type"
                  class="form-control form-select"
                  style="width:160px"
                  onchange="this.form.submit()">

            <option value="tous"
              <%= filtreType==='tous' ? 'selected' : '' %>>
              Tous types
            </option>

            <option value="sur_place"
              <%= filtreType==='sur_place' ? 'selected' : '' %>>
              🪑 Sur place
            </option>

            <option value="a_emporter"
              <%= filtreType==='a_emporter' ? 'selected' : '' %>>
              🛍️ À emporter
            </option>

            <option value="livraison"
              <%= filtreType==='livraison' ? 'selected' : '' %>>
              🛵 Livraison
            </option>

          </select>

          <input type="date"
                 name="date"
                 class="form-control"
                 style="width:170px"
                 value="<%= filtreDate %>"
                 onchange="this.form.submit()"/>

        </form>

      </div>

    </div>

    <!-- COMMANDES -->
    <div id="commandesList">

      <% if(commandes.length === 0){ %>

        <div class="empty-state">

          <div class="empty-state-icon">
            <i class="bi bi-bag-x"></i>
          </div>

          <h3>Aucune commande</h3>

          <p>
            Les commandes apparaissent ici en temps réel.
          </p>

        </div>

      <% } else { %>

        <% commandes.forEach(cmd => { %>

          <div class="cmd-card" id="cmd-<%= cmd._id %>">

            <div class="cmd-card-body">

              <div class="cmd-client-name">

                <%= cmd.client_nom %>

              </div>

              <div class="cmd-items-list">

                <% cmd.items.forEach(item => { %>

                  <div class="cmd-item-row">

                    <span class="cmd-qty">
                      <%= item.quantite %>×
                    </span>

                    <span class="cmd-item-name">
                      <%= item.nom %>
                    </span>

                    <span class="cmd-item-price">
                      <%= (item.prix * item.quantite).toLocaleString('fr-FR') %> F
                    </span>

                  </div>

                <% }) %>

              </div>

            </div>

            <div class="cmd-card-footer">

              <div class="cmd-total">
                <%= cmd.total.toLocaleString('fr-FR') %> FCFA
              </div>

            </div>

          </div>

        <% }) %>

      <% } %>

    </div>

    <!-- MAP -->
    <div id="mapSection" class="card" style="margin-top:1.5rem">

      <div class="card-header-bar">

        <div>

          <div class="card-title">
            <i class="bi bi-map"></i>
            Carte des livraisons
          </div>

          <div class="card-subtitle">
            Positions des commandes en livraison
          </div>

        </div>

        <div style="display:flex;gap:8px;align-items:center">

          <span id="mapCmdBadge" class="badge badge-gray">

            Chargement...

          </span>

          <button id="refreshMap"
                  onclick="initCommandesMapPage()"
                  class="btn btn-secondary btn-sm">

            <i class="bi bi-arrow-clockwise"></i>

            Actualiser

          </button>

        </div>

      </div>

      <div class="commandes-map-wrapper">

        <div id="commandesMap"></div>

      </div>

      <div class="card-body" style="padding:.75rem 1.25rem">

        <div class="map-legend">

          <div class="legend-item">
            <div class="legend-dot" style="background:#F59E0B"></div>
            En attente
          </div>

          <div class="legend-item">
            <div class="legend-dot" style="background:#3B82F6"></div>
            En préparation
          </div>

          <div class="legend-item">
            <div class="legend-dot" style="background:#8B5CF6"></div>
            En livraison
          </div>

          <div class="legend-item">
            <div class="legend-dot" style="background:#10B981"></div>
            Livrée
          </div>

        </div>

      </div>

    </div>

  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/commandes.js"></script>
<script src="/js/app.js"></script>

<script>
const restaurantId = '<%= restaurantId %>';
</script>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/map-dashboard.js"></script>

<script>

async function initCommandesMapPage() {

  try {

    const [commandes, restaurant] = await Promise.all([

      fetch('/maps/commandes').then(r => r.json()),

      fetch('/maps/restaurant').then(r => r.json())

    ]);

    const badge = document.getElementById('mapCmdBadge');

    if (badge) {

      badge.className =
        commandes.length > 0
          ? 'badge badge-success'
          : 'badge badge-gray';

      badge.textContent =
        commandes.length > 0
          ? commandes.length + ' livraison(s)'
          : 'Aucune livraison';

    }

    initCommandesMap(commandes, restaurant);

    setTimeout(() => {

      if (window.commandesMap) {

        window.commandesMap.invalidateSize();

      }

    }, 300);

  } catch(e) {

    console.error('Erreur carte commandes:', e);

  }

}

initCommandesMapPage();

</script>

</body>
</html>