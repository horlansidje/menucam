<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>

  <title><%= restaurant.nom %> — Menu</title>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="/css/menu-client.css"/>

  <meta name="theme-color" content="#1A1209"/>
</head>

<body>

<header class="menu-header">

  <div class="header-wax"></div>

  <div class="header-content">

    <% if(restaurant.logo){ %>

      <img
        src="<%= restaurant.logo %>"
        alt="<%= restaurant.nom %>"
        class="resto-logo"
      />

    <% } else { %>

      <div class="resto-logo-placeholder">
        🍽️
      </div>

    <% } %>

    <div class="resto-info">

      <h1 class="resto-name">
        <%= restaurant.nom %>
      </h1>

      <% if(restaurant.adresse || restaurant.ville){ %>

        <span class="resto-adresse">

          📍

          <%= [restaurant.adresse, restaurant.ville]
                .filter(Boolean)
                .join(', ')
          %>

        </span>

      <% } %>

      <% if(restaurant.telephone){ %>

        <a
          href="tel:<%= restaurant.telephone %>"
          class="resto-tel"
        >
          📞 <%= restaurant.telephone %>
        </a>

      <% } %>

      <% if(restaurant.description){ %>

        <p class="resto-desc">
          <%= restaurant.description %>
        </p>

      <% } %>

      <% if(restaurant.note_moyenne){ %>

        <div class="resto-rating">

          <span class="rating-val">
            ⭐ <%= restaurant.note_moyenne %>
          </span>

          <span class="rating-count">
            (<%= restaurant.nb_avis || 0 %> avis)
          </span>

        </div>

      <% } %>

    </div>

  </div>

</header>

<%
  const catNames = Object.keys(categories);
%>

<% if(catNames.length > 0){ %>

  <nav class="cat-nav" id="catNav">

    <% catNames.forEach((cat, i) => { %>

      <button
        class="cat-btn <%= i === 0 ? 'active' : '' %>"
        onclick="scrollToCat('<%= cat %>')"
      >
        <%= cat %>
      </button>

    <% }); %>

  </nav>

<% } %>

<main class="menu-main">

  <% if(catNames.length === 0){ %>

    <div class="menu-empty">

      <div style="font-size:3rem;margin-bottom:1rem">
        🍽️
      </div>

      <p>
        Le menu sera disponible bientôt.
      </p>

    </div>

  <% } else { %>

    <% catNames.forEach(cat => { %>

      <section
        class="menu-section"
        id="cat-<%= cat.replace(/\s/g,'-') %>"
        data-cat="<%= cat %>"
      >

        <h2 class="cat-title">
          <%= cat %>
        </h2>

        <div class="plats-list">

          <% categories[cat].forEach(plat => { %>

            <div
              class="plat-item"
              onclick="ajouterAuPanier(
                '<%= plat._id %>',
                '<%= plat.nom.replace(/'/g, '\\\\\'') %>',
                <%= plat.promo_prix || plat.prix %>
              )"
            >

              <div class="plat-info">

                <h3 class="plat-nom">
                  <%= plat.nom %>
                </h3>

                <% if(plat.description){ %>

                  <p class="plat-desc">
                    <%= plat.description %>
                  </p>

                <% } %>

                <div class="plat-prix">

                  <% if(plat.promo_prix){ %>

                    <span class="promo-prix">
                      <%= plat.prix.toLocaleString('fr-FR') %> F
                    </span>

                  <% } %>

                  <%= (plat.promo_prix || plat.prix)
                        .toLocaleString('fr-FR')
                  %> FCFA

                </div>

              </div>

              <div class="plat-photo-wrap <%= !plat.photo ? 'no-photo' : '' %>">

                <% if(plat.photo){ %>

                  <img
                    src="<%= plat.photo %>"
                    alt="<%= plat.nom %>"
                    class="plat-photo"
                    loading="lazy"
                  />

                <% } %>

                <% if(plat.promo_prix){ %>

                  <span class="promo-badge-item">
                    PROMO
                  </span>

                <% } %>

                <button
                  class="add-btn"
                  id="btn-<%= plat._id %>"
                >
                  +
                </button>

              </div>

            </div>

          <% }); %>

        </div>

      </section>

    <% }); %>

    <!-- AVIS -->
    <% if(avis && avis.length > 0){ %>

      <section style="margin-bottom:2rem">

        <h2 class="cat-title">
          ⭐ Avis clients
        </h2>

        <div class="avis-section" style="padding:0">

          <% avis.slice(0,3).forEach(a => { %>

            <div class="avis-card-pub">

              <div class="avis-header-pub">

                <div>

                  <div class="avis-nom-pub">
                    <%= a.client_nom %>
                  </div>

                  <div class="stars">

                    <% for(let i = 1; i <= 5; i++){ %>

                      <span
                        class="star star-sm <%= i <= a.note ? 'active' : '' %>"
                      >
                        ★
                      </span>

                    <% } %>

                  </div>

                </div>

                <div style="font-size:12px;color:#9a8a7a">

                  <%= new Date(a.createdAt)
                        .toLocaleDateString('fr-FR')
                  %>

                </div>

              </div>

              <% if(a.texte){ %>

                <p
                  style="
                    font-size:13px;
                    color:#6b6154;
                    line-height:1.6
                  "
                >
                  <%= a.texte %>
                </p>

              <% } %>

              <% if(a.reponse){ %>

                <div
                  style="
                    background:#f5e6d0;
                    padding:8px 12px;
                    border-radius:8px;
                    font-size:12px;
                    color:#6b4226;
                    margin-top:8px;
                    border-left:3px solid #e07b39
                  "
                >

                  🍽️ <%= a.reponse %>

                </div>

              <% } %>

            </div>

          <% }); %>

        </div>

      </section>

    <% } %>

  <% } %>

</main>

<!-- PANIER -->
<div
  class="panier-bar"
  id="panierBar"
  style="display:none"
>

  <div class="panier-summary">

    <span
      class="panier-count"
      id="panierCount"
    >
      0 article
    </span>

    <span
      class="panier-total"
      id="panierTotal"
    >
      0 FCFA
    </span>

  </div>

  <button
    class="panier-btn"
    onclick="ouvrirPanier()"
  >
    🛒 Mon panier
  </button>

</div>

<!-- MODAL PANIER -->
<div
  class="panier-overlay"
  id="panierOverlay"
  style="display:none"
>

  <div class="panier-modal">

    <div class="panier-header">

      <h2>🛒 Mon panier</h2>

      <button
        class="panier-close"
        onclick="fermerPanier()"
      >
        ✕
      </button>

    </div>

    <div
      class="panier-items"
      id="panierItems"
    ></div>

    <div class="panier-footer">

  <!-- TYPE LIVRAISON -->
  <p
    style="
      font-size:13px;
      font-weight:600;
      color:var(--gris);
      margin-bottom:8px
    "
  >
    Type de commande
  </p>

  <div class="delivery-options">

    <div
      class="delivery-opt selected"
      data-type="sur_place"
      onclick="selectDelivery(this,'sur_place')"
    >
      <div class="opt-icon">🪑</div>
      <div class="opt-label">Sur place</div>
    </div>

    <div
      class="delivery-opt"
      data-type="a_emporter"
      onclick="selectDelivery(this,'a_emporter')"
    >
      <div class="opt-icon">🛍️</div>
      <div class="opt-label">À emporter</div>
    </div>

    <div
      class="delivery-opt"
      data-type="livraison"
      onclick="selectDelivery(this,'livraison')"
    >
      <div class="opt-icon">🛵</div>
      <div class="opt-label">Livraison</div>
    </div>

  </div>

  <!-- INFOS CLIENT -->
  <div class="panier-infos">

    <div class="panier-info-row">
      <label>Votre prénom</label>

      <input
        type="text"
        id="clientNom"
        placeholder="Ex: Jean-Paul"
        class="panier-input"
      />
    </div>

    <div class="panier-info-row">
      <label>Téléphone</label>

      <input
        type="tel"
        id="clientTel"
        placeholder="6XX XXX XXX"
        class="panier-input"
      />
    </div>

    <div
      class="panier-info-row"
      id="tableRow"
    >
      <label>N° de table</label>

      <input
        type="text"
        id="clientTable"
        placeholder="Ex: 5"
        class="panier-input"
      />
    </div>

    <div
      class="panier-info-row"
      id="adresseRow"
      style="display:none"
    >
      <label>Adresse de livraison</label>

      <input
        type="text"
        id="clientAdresse"
        placeholder="Ex: Rue de la Joie"
        class="panier-input"
      />
    </div>

    <div
      class="panier-info-row"
      id="quartierRow"
      style="display:none"
    >
      <label>Quartier</label>

      <input
        type="text"
        id="clientQuartier"
        placeholder="Ex: Akwa"
        class="panier-input"
      />
    </div>

    <div class="panier-info-row">
      <label>Note spéciale</label>

      <input
        type="text"
        id="clientNote"
        placeholder="Sans piment..."
        class="panier-input"
      />
    </div>

  </div>

  <!-- CODE PROMO -->
  <div class="promo-row">

    <input
      type="text"
      id="promoCode"
      placeholder="Code promo"
      class="panier-input"
      style="text-transform:uppercase"
    />

    <button
      onclick="verifierPromo()"
      class="btn"
      style="
        background:var(--vert);
        color:#fff;
        padding:10px 16px;
        border-radius:8px;
        border:none;
        cursor:pointer;
        font-weight:600
      "
    >
      Appliquer
    </button>

  </div>

  <div
    id="promoMsg"
    style="
      font-size:13px;
      margin-bottom:10px;
      min-height:18px
    "
  ></div>

  <!-- RECAP -->
  <div
    class="panier-recap"
    id="panierRecap"
  ></div>

  <!-- PAIEMENT -->
  <p class="payment-label">
    Mode de paiement
  </p>

  <div class="payment-options">

    <div
      class="pay-opt selected"
      data-pay="whatsapp"
      onclick="selectPay(this,'whatsapp')"
    >
      <div class="pay-icon">💬</div>
      <div class="pay-label">WhatsApp</div>
    </div>

    <div
      class="pay-opt"
      data-pay="mtn"
      onclick="selectPay(this,'mtn')"
    >
      <div class="pay-icon">📱</div>
      <div class="pay-label">MTN Money</div>
    </div>

    <div
      class="pay-opt"
      data-pay="orange"
      onclick="selectPay(this,'orange')"
    >
      <div class="pay-icon">🟠</div>
      <div class="pay-label">Orange</div>
    </div>

  </div>

  <!-- BTN COMMANDER -->
  <button
    class="btn-commander whatsapp"
    id="btnCommander"
    onclick="commander()"
  >
    🛒 Commander via WhatsApp
  </button>

</div>

  </div>

</div>

<script>

const RESTAURANT_ID =
  '<%= restaurant._id %>';

const RESTAURANT_TEL =
  '<%= restaurant.telephone
      ? restaurant.telephone.replace(/\s/g,"")
      : ""
  %>';

const RESTAURANT_NOM =
  '<%= restaurant.nom.replace(/'/g,"\\\\'") %>';

</script>

<script src="/js/menu-client.js"></script>

</body>
</html>