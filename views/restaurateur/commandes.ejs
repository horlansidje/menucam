<%- include('../partials/head', {title: 'Commandes'}) %>
<link rel="stylesheet" href="/css/dashboard.css"/>
<%- include('../partials/navbar', {activePage: 'commandes'}) %>

<div class="page-wrapper">
  <div class="page-header">
    <div>
      <h1 class="page-title">Commandes</h1>
      <p class="page-sub">Gérez et suivez toutes vos commandes en temps réel</p>
    </div>
    <div class="live-indicator"><span class="live-dot"></span> Temps réel</div>
  </div>

  <% if(success && success.length > 0) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <!-- Stats commandes -->
  <div class="commandes-stats">
    <div class="cstat en-attente"><span class="cstat-num"><%= stats.enAttente %></span><span>En attente</span></div>
    <div class="cstat en-prep"><span class="cstat-num"><%= stats.enPreparation %></span><span>En préparation</span></div>
    <div class="cstat servies"><span class="cstat-num"><%= stats.servies %></span><span>Servies</span></div>
    <div class="cstat ca"><span class="cstat-num"><%= stats.caTodal.toLocaleString('fr-FR') %></span><span>FCFA aujourd'hui</span></div>
  </div>

  <!-- Filtres -->
  <form method="GET" action="/commandes" class="filters-form">
    <select name="statut" onchange="this.form.submit()">
      <option value="toutes"   <%= filtreStatut==='toutes' ? 'selected':'' %>>Toutes les commandes</option>
      <option value="en_attente"    <%= filtreStatut==='en_attente' ? 'selected':'' %>>⏳ En attente</option>
      <option value="en_preparation" <%= filtreStatut==='en_preparation' ? 'selected':'' %>>👨‍🍳 En préparation</option>
      <option value="servie"   <%= filtreStatut==='servie' ? 'selected':'' %>>✅ Servies</option>
      <option value="annulee"  <%= filtreStatut==='annulee' ? 'selected':'' %>>❌ Annulées</option>
    </select>
    <input type="date" name="date" value="<%= filtreDate %>" onchange="this.form.submit()"/>
    <% if(filtreStatut !== 'toutes' || filtreDate) { %>
      <a href="/commandes" class="btn-reset-filter">✕ Réinitialiser</a>
    <% } %>
  </form>

  <!-- Liste commandes -->
  <div id="commandesList">
    <% if(commandes.length === 0) { %>
      <div class="empty-page">
        <div class="empty-icon-lg">📦</div>
        <h2>Aucune commande</h2>
        <p>Les commandes de vos clients apparaîtront ici en temps réel dès qu'ils scannent votre QR code.</p>
      </div>
    <% } else { %>
      <% commandes.forEach(cmd => { %>
        <div class="commande-detail-card" id="cmd-<%= cmd._id %>">
          <div class="cmd-header">
            <div class="cmd-client">
              <span class="cmd-icon">👤</span>
              <div>
                <strong><%= cmd.client_nom %></strong>
                <% if(cmd.client_table) { %><span class="cmd-table">Table <%= cmd.client_table %></span><% } %>
              </div>
            </div>
            <div class="cmd-meta">
              <span class="cmd-time">🕐 <%= new Date(cmd.createdAt).toLocaleString('fr-FR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></span>
              <span class="statut-badge statut-<%= cmd.statut %>" id="statut-<%= cmd._id %>">
                <%= cmd.statut === 'en_attente' ? '⏳ En attente' :
                    cmd.statut === 'en_preparation' ? '👨‍🍳 En préparation' :
                    cmd.statut === 'servie' ? '✅ Servie' : '❌ Annulée' %>
              </span>
            </div>
          </div>

          <div class="cmd-items">
            <% cmd.items.forEach(item => { %>
              <div class="cmd-item">
                <span class="item-qty"><%= item.quantite %>×</span>
                <span class="item-nom"><%= item.nom %></span>
                <span class="item-prix"><%= (item.prix * item.quantite).toLocaleString('fr-FR') %> FCFA</span>
              </div>
            <% }); %>
          </div>

          <% if(cmd.note) { %>
            <div class="cmd-note">📝 <em><%= cmd.note %></em></div>
          <% } %>

          <div class="cmd-footer">
            <span class="cmd-total">Total : <strong><%= cmd.total.toLocaleString('fr-FR') %> FCFA</strong></span>
            <div class="cmd-statut-actions">
              <% if(cmd.statut === 'en_attente') { %>
                <button class="btn-statut prep" onclick="changerStatut('<%= cmd._id %>', 'en_preparation', this)">👨‍🍳 Prendre en charge</button>
                <button class="btn-statut annul" onclick="changerStatut('<%= cmd._id %>', 'annulee', this)">❌ Annuler</button>
              <% } else if(cmd.statut === 'en_preparation') { %>
                <button class="btn-statut serve" onclick="changerStatut('<%= cmd._id %>', 'servie', this)">✅ Marquer comme servie</button>
              <% } %>
              <form method="POST" action="/commandes/<%= cmd._id %>/supprimer" style="display:inline"
                onsubmit="return confirm('Supprimer cette commande ?')">
                <button type="submit" class="btn-statut del">🗑️</button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/commandes.js"></script>
<script src="/js/navbar.js"></script>
<script>
  const restaurantId = '<%= restaurantId %>';
</script>
</body>
</html>
