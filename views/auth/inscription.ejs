<%- include('../partials/head', {title: 'Inscription'}) %>
<link rel="stylesheet" href="/css/auth.css"/>
<div class="auth-page">
  <div class="auth-left">
    <a href="/" class="back-link">← Retour</a>
    <div class="auth-brand">
      <span class="brand-icon">🍽️</span>
      <span class="brand-name">MenuCam</span>
    </div>
    <h1>Créez votre compte restaurant</h1>
    <p>Votre menu en ligne prêt en 5 minutes.</p>

    <% if(error && error.length > 0) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if(success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <form method="POST" action="/auth/inscription" class="auth-form">
      <div class="form-group">
        <label>Nom du restaurant *</label>
        <input type="text" name="nom" placeholder="Ex: Chez Maman Biya" required/>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" placeholder="contact@monresto.cm" required/>
        </div>
        <div class="form-group">
          <label>Téléphone *</label>
          <input type="tel" name="telephone" placeholder="6XX XXX XXX" required/>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Adresse</label>
          <input type="text" name="adresse" placeholder="Quartier Akwa, Rue..."/>
        </div>
        <div class="form-group">
          <label>Ville</label>
          <select name="ville">
            <option value="Douala">Douala</option>
            <option value="Yaoundé">Yaoundé</option>
            <option value="Bafoussam">Bafoussam</option>
            <option value="Bamenda">Bamenda</option>
            <option value="Garoua">Garoua</option>
            <option value="Autre">Autre</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Mot de passe *</label>
          <input type="password" name="password" placeholder="Min. 6 caractères" required minlength="6"/>
        </div>
        <div class="form-group">
          <label>Confirmer le mot de passe *</label>
          <input type="password" name="password2" placeholder="Répétez votre mot de passe" required/>
        </div>
      </div>
      <button type="submit" class="btn-submit">Créer mon compte →</button>
    </form>
    <p class="auth-switch">Déjà un compte ? <a href="/auth/connexion">Se connecter</a></p>
  </div>
  <div class="auth-right">
    <div class="auth-illustration">
      <div class="illus-qr">
        <div class="qr-fake">
          <div class="qr-corner tl"></div>
          <div class="qr-corner tr"></div>
          <div class="qr-corner bl"></div>
          <div class="qr-dots"></div>
        </div>
        <p>Votre QR code unique</p>
      </div>
    </div>
  </div>
</div>
</body>
</html>
