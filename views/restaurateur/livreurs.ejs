<%- include('../partials/head', {title:'Livreurs'}) %>
<%- include('../partials/sidebar', {activePage:'livreurs'}) %>
<div class="main-content">
  <div class="topbar"><div class="topbar-left"><button class="sidebar-toggle" id="sidebarToggle"><i class="bi bi-list"></i></button><div class="topbar-title">Gestion des livreurs</div></div></div>
  <div class="page-body">
    <% if(error&&error.length>0){%><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i><%=error%></div><%}%>
    <% if(success&&success.length>0){%><div class="alert alert-success"><i class="bi bi-check-circle"></i><%=success%></div><%}%>
    <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start">
      <div>
        <% if(livreurs.length===0){ %>
          <div class="empty-state"><div class="empty-state-icon"><i class="bi bi-scooter"></i></div><h3>Aucun livreur</h3><p>Ajoutez vos livreurs pour gérer les livraisons.</p></div>
        <% } else { %>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem">
            <%livreurs.forEach(l=>{%>
              <div class="card">
                <div class="card-body" style="display:flex;align-items:center;gap:1rem">
                  <div style="width:52px;height:52px;border-radius:50%;background:var(--brand-light);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;border:2px solid var(--border)">🛵</div>
                  <div style="flex:1;min-width:0">
                    <div style="font-weight:700;font-size:15px"><%=l.nom%></div>
                    <div style="font-size:13px;color:var(--text-secondary)"><i class="bi bi-telephone"></i> <%=l.telephone%></div>
                    <%if(l.moto){%><div style="font-size:12px;color:var(--text-tertiary)">🏍️ <%=l.moto%></div><%}%>
                    <%if(l.zone){%><div style="font-size:12px;color:var(--text-tertiary)"><i class="bi bi-geo-alt"></i> <%=l.zone%></div><%}%>
                    <div style="font-size:11px;color:var(--accent-dark);margin-top:2px"><i class="bi bi-check2-circle"></i> <%=l.commandes_livrees||0%> livraisons</div>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end">
                    <select onchange="updateStatut('<%=l._id%>',this.value)" class="form-control form-select" style="font-size:12px;padding:4px 8px;height:32px;width:120px">
                      <option value="disponible" <%= l.statut==='disponible' ? 'selected' : '' %>✅ Disponible</option>
                      <option value="occupé"     <%= l.statut==='occupé' ? 'selected' : '' %>🟡 Occupé</option>
                      <option value="inactif"    <%= l.statut==='inactif' ? 'selected' : '' %>⚫ Inactif</option>
                    </select>
                    <form method="POST" action="/livreurs/<%=l._id%>/supprimer" onsubmit="return confirm('Supprimer ?')"><button type="submit" class="btn btn-sm btn-secondary btn-icon"><i class="bi bi-trash3"></i></button></form>
                  </div>
                </div>
              </div>
            <%});%>
          </div>
        <%}%>
      </div>
      <div class="card">
        <div class="card-header-bar"><div class="card-title">➕ Nouveau livreur</div></div>
        <div class="card-body">
          <form method="POST" action="/livreurs/nouveau">
            <div style="margin-bottom:.9rem"><label class="form-label">Nom complet *</label><input type="text" name="nom" class="form-control" placeholder="Ex: Jean-Paul Mbarga" required/></div>
            <div style="margin-bottom:.9rem"><label class="form-label">Téléphone *</label><input type="tel" name="telephone" class="form-control" placeholder="6XX XXX XXX" required/></div>
            <div style="margin-bottom:.9rem"><label class="form-label">Type de moto</label><input type="text" name="moto" class="form-control" placeholder="Ex: TVS King, Benelli"/></div>
            <div style="margin-bottom:1.25rem"><label class="form-label">Zone de livraison</label><input type="text" name="zone" class="form-control" placeholder="Ex: Akwa, Bonamoussadi"/></div>
            <button type="submit" class="btn btn-primary" style="width:100%"><i class="bi bi-person-plus"></i> Ajouter le livreur</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
async function updateStatut(id, statut) {
  await fetch(`/livreurs/${id}/statut`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({statut}) });
  showToast('Statut mis à jour', 'success');
}
</script>
<script src="/js/app.js"></script>
</body></html>
