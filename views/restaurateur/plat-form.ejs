<%- include('../partials/head',{title:plat?'Modifier plat':'Nouveau plat'}) %>
<link rel="stylesheet" href="/css/dashboard.css"/>
<%- include('../partials/navbar',{activePage:'plats'}) %>
<div class="page-wrapper">
  <div class="page-header"><div><a href="/plats" class="back-link">← Retour</a><h1 class="page-title"><%=plat?'Modifier : '+plat.nom:'Nouveau plat'%></h1></div></div>
  <% if(error&&error.length>0){%><div class="alert alert-error"><%=error%></div><%}%>
  <div class="form-card">
    <form method="POST" action="<%=plat?'/plats/'+plat._id+'/modifier':'/plats/nouveau'%>" enctype="multipart/form-data">
      <div class="form-grid">
        <div>
          <div class="form-group"><label>Photo du plat</label>
            <div class="photo-upload" id="photoUpload">
              <%if(plat&&plat.photo){%><img src="<%=plat.photo%>" id="photoPreview" class="photo-preview"/><%}else{%>
              <div class="photo-placeholder" id="photoPlaceholder"><span class="upload-icon">📸</span><span>Cliquez pour ajouter</span><span class="upload-sub">JPG, PNG · Max 5 Mo</span></div>
              <img id="photoPreview" class="photo-preview" style="display:none"/><%}%>
              <input type="file" name="photo" id="photoInput" accept="image/*" style="display:none"/>
            </div>
          </div>
          <div class="form-group">
            <div class="toggle-wrap"><label>Disponible au menu</label>
              <label class="toggle"><input type="checkbox" name="disponible" <%=!plat||plat.disponible?'checked':''%>/><span class="toggle-slider"></span></label>
            </div>
          </div>
        </div>
        <div>
          <div class="form-group"><label>Nom du plat *</label><input type="text" name="nom" value="<%=plat?plat.nom:''%>" placeholder="Ex: Ndolé spécial, Poulet DG..." required/></div>
          <div class="form-group"><label>Description</label><textarea name="description" rows="3" placeholder="Ingrédients, spécialités..."><%=plat?plat.description:''%></textarea></div>
          <div class="form-row">
            <div class="form-group"><label>Prix (FCFA) *</label><input type="number" name="prix" value="<%=plat?plat.prix:''%>" placeholder="3500" min="0" step="50" required/></div>
            <div class="form-group"><label>Catégorie *</label>
              <input type="text" name="categorie" value="<%=plat?plat.categorie:''%>" placeholder="Ex: Plats principaux, Boissons..." list="cats" required/>
              <datalist id="cats"><option value="Entrées & Collations"/><option value="Plats principaux"/><option value="Viandes"/><option value="Poissons"/><option value="Végétarien"/><option value="Grillades & Brochettes"/><option value="Accompagnements"/><option value="Desserts"/><option value="Jus naturels"/><option value="Boissons"/><option value="Bières"/><option value="Spécialités camerounaises"/></datalist>
            </div>
          </div>
        </div>
      </div>
      <div class="form-actions"><a href="/plats" class="btn btn-outline">Annuler</a><button type="submit" class="btn btn-primary"><%=plat?'💾 Enregistrer':'➕ Ajouter le plat'%></button></div>
    </form>
  </div>
</div>
<script>
const pu=document.getElementById('photoUpload'),pi=document.getElementById('photoInput'),pp=document.getElementById('photoPreview'),ph=document.getElementById('photoPlaceholder');
pu.addEventListener('click',()=>pi.click());
pi.addEventListener('change',e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{pp.src=ev.target.result;pp.style.display='block';if(ph)ph.style.display='none';};r.readAsDataURL(f);});
</script>
<script src="/js/navbar.js"></script>
</body></html>
