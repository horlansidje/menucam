<%- include('../partials/head', {title:'Inscription'}) %>
<style>
.auth-page{display:grid;grid-template-columns:1fr 1fr;min-height:100vh}
.auth-panel-left{background:#fff;padding:3rem;display:flex;flex-direction:column;justify-content:center;max-width:520px;width:100%;margin:0 auto}
.auth-panel-right{background:linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f172a 100%);display:flex;align-items:center;justify-content:center;padding:2rem;position:relative;overflow:hidden}
.auth-panel-right::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(245,158,11,.15) 0,transparent 60%)}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:2rem}
.auth-logo-icon{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#F59E0B,#D97706);display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.auth-logo-name{font-family:'Bricolage Grotesque',sans-serif;font-size:1.35rem;font-weight:800;color:#111}
.auth-title{font-family:'Bricolage Grotesque',sans-serif;font-size:1.7rem;font-weight:800;color:#111;margin-bottom:.4rem}
.auth-sub{color:#6B7280;font-size:14px;margin-bottom:1.75rem}
.form-field{margin-bottom:.9rem}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.btn-submit{width:100%;padding:12px;background:#F59E0B;color:#111;border:none;border-radius:10px;font-weight:700;font-size:15px;cursor:pointer;transition:all .2s;font-family:inherit;margin-top:.5rem;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-submit:hover{background:#D97706;transform:translateY(-1px)}
.auth-switch{font-size:14px;color:#6B7280;margin-top:1rem;text-align:center}
.auth-switch a{color:#F59E0B;font-weight:600}
.back-link{display:inline-flex;align-items:center;gap:5px;color:#6B7280;font-size:13px;margin-bottom:1.75rem;transition:color .2s}
.back-link:hover{color:#111}
.illus-feats{position:relative;z-index:1;display:flex;flex-direction:column;gap:10px}
.illus-feat{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:12px 16px}
.illus-feat-icon{width:36px;height:36px;border-radius:10px;background:rgba(245,158,11,.15);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.illus-feat-text{font-size:13px;color:rgba(255,255,255,.7);font-weight:500}
@media(max-width:768px){.auth-page{grid-template-columns:1fr}.auth-panel-right{display:none}.auth-panel-left{max-width:100%;padding:2rem 1.5rem}.form-row{grid-template-columns:1fr}}
</style>
<div class="auth-page">
  <div class="auth-panel-left">
    <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> Retour</a>
    <div class="auth-logo"><div class="auth-logo-icon">🍽️</div><div class="auth-logo-name">MenuCam</div></div>
    <h1 class="auth-title">Créez votre compte</h1>
    <p class="auth-sub">Menu digital prêt en 5 minutes. Gratuit pour commencer.</p>
    <% if(error&&error.length>0){%><div class="alert alert-danger" style="margin-bottom:1rem"><i class="bi bi-exclamation-triangle"></i><%=error%></div><%}%>
    <form method="POST" action="/auth/inscription">
      <div class="form-field"><label class="form-label">Nom du restaurant *</label><div class="input-group"><i class="bi bi-shop"></i><input type="text" name="nom" class="form-control" placeholder="Ex: Chez Maman Biya" required/></div></div>
      <div class="form-row">
        <div class="form-field"><label class="form-label">Email *</label><input type="email" name="email" class="form-control" placeholder="contact@monresto.cm" required/></div>
        <div class="form-field"><label class="form-label">Téléphone *</label><input type="tel" name="telephone" class="form-control" placeholder="6XX XXX XXX" required/></div>
      </div>
      <div class="form-row">
        <div class="form-field"><label class="form-label">Adresse</label><input type="text" name="adresse" class="form-control" placeholder="Quartier, Rue..."/></div>
        <div class="form-field"><label class="form-label">Ville</label><select name="ville" class="form-control form-select"><option>Douala</option><option>Yaoundé</option><option>Bafoussam</option><option>Bamenda</option><option>Garoua</option><option>Autre</option></select></div>
      </div>
      <div class="form-row">
        <div class="form-field"><label class="form-label">Mot de passe *</label><input type="password" name="password" class="form-control" placeholder="Min. 6 caractères" required minlength="6"/></div>
        <div class="form-field"><label class="form-label">Confirmer *</label><input type="password" name="password2" class="form-control" placeholder="Répétez" required/></div>
      </div>
      <button type="submit" class="btn-submit"><i class="bi bi-rocket-takeoff"></i> Créer mon compte gratuitement</button>
    </form>
    <p class="auth-switch">Déjà un compte ? <a href="/auth/connexion">Se connecter</a></p>
  </div>
  <div class="auth-panel-right">
    <div class="illus-feats">
      <div class="illus-feat"><div class="illus-feat-icon">📱</div><div class="illus-feat-text">Menu QR Code unique pour votre restaurant</div></div>
      <div class="illus-feat"><div class="illus-feat-icon">🛵</div><div class="illus-feat-text">Gestion livraison avec suivi temps réel</div></div>
      <div class="illus-feat"><div class="illus-feat-icon">📄</div><div class="illus-feat-text">Reçus PDF professionnels automatiques</div></div>
      <div class="illus-feat"><div class="illus-feat-icon">💳</div><div class="illus-feat-text">Paiement MTN &amp; Orange Money intégré</div></div>
      <div class="illus-feat"><div class="illus-feat-icon">📊</div><div class="illus-feat-text">Analytics et statistiques avancées</div></div>
    </div>
  </div>
</div>
</body></html>
